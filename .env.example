# MikroTik RouterOS Connection
ROUTEROS_HOST=192.168.88.1
ROUTEROS_PORT=8728
ROUTEROS_USERNAME=admin
ROUTEROS_PASSWORD=
ROUTEROS_SECURE=false
ROUTEROS_TIMEOUT=30000

# Discovery
DISCOVERY_ENABLED=true
DISCOVERY_CACHE_TTL=86400000

# Logging
LOG_LEVEL=info

# Transport (stdio | http)
TRANSPORT=stdio
HTTP_PORT=3000
