# MikroTik RouterOS Connection
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_SECURE=false
MIKROTIK_TIMEOUT=30000

# Transport: stdio (default) or http
MCP_TRANSPORT=stdio

# HTTP transport settings (used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000

# Bearer token for HTTP transport. REQUIRED when binding to a non-loopback
# interface, since anyone who can reach the port can control the router.
# Generate with: openssl rand -hex 32
MIKROTIK_MCP_TOKEN=

# Discovery
DISCOVERY_ENABLED=true
DISCOVERY_CACHE_TTL=86400000

# Logging
LOG_LEVEL=info
